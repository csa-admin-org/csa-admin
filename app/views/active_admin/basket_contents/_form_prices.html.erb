<%= turbo_frame_tag "basket-content-form-prices", data: { "basket-content-distribution-target": "frame" }, class: "hidden" do %>
  <% if unit.present? %>
    <span data-unit="<%= unit %>"></span>
  <% end %>

  <% if unit.present? %>
    <% surplus = local_assigns[:total_quantity_surplus].to_i %>
    <% surplus_unit = local_assigns[:total_quantity_surplus_unit] %>
    <span data-total-product-value>
      <div class="ms-6 flex-col items-center justify-center text-center">
        <% if local_assigns[:total_product_value].to_f.positive? %>
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400">
            <%= cur(local_assigns[:total_product_value]) %>
          </span>
        <% end %>

        <span
          class="block text-xs text-gray-500 dark:text-gray-400"
          data-total-quantity-surplus
        >
          <%= t("basket_content.surplus", quantity: display_quantity(surplus, surplus_unit)) %>
        </span>
      </div>
    </span>
  <% end %>

  <% baskets_counts.each do |basket_size_id, count| %>
    <span
      data-baskets-count-for="<%= basket_size_id %>"
      data-baskets-count="<%= count %>"
    ></span>
  <% end %>

  <% has_range = prices_data.any? { |_, info| info[:totals].size > 1 } %>

  <% prices_data.each do |basket_size_id, info| %>
    <div data-basket-size-id="<%= basket_size_id %>">
      <div class="mt-2 flex items-center justify-around gap-x-6 text-sm md:mt-0">
        <div class="w-28 flex-col items-center justify-center text-center">
          <span
            class="
              flex items-center justify-center gap-x-2 font-medium
              text-gray-700 dark:text-gray-200
            "
          >
            <%# Baskets count %>
            <span data-baskets-count-text><%= info[:baskets_count] %>x</span>

            <%# Product price per basket %>
            <span class="text-gray-500 dark:text-gray-400">
              <%= cur(info[:product_price]) %>
            </span>
          </span>

          <%# Total value for all baskets of this size %>
          <span
            class="text-xs text-gray-500 dark:text-gray-400"
            data-total-value="<%= info[:total_value] %>"
          >
            <%= cur(info[:total_value]) %>
          </span>
        </div>

        <%# Delivery total(s) %>
        <% if info[:totals].one? %>
          <div class="flex flex-col items-center <%= "w-50 text-center" if has_range %>">
            <span class="font-bold text-gray-700 dark:text-gray-200">
              <%= cur(info[:totals].first) %>
            </span>

            <%= display_basket_price_diff(info[:basket_price], info[:totals].first - info[:basket_price]) %>
          </div>
        <% elsif info[:totals].any? %>
          <div class="flex w-50 items-center justify-center gap-x-2">
            <% info[:totals].each_with_index do |total, i| %>
              <% if i > 0 %>
                <span class="text-lg font-light text-gray-400">–</span>
              <% end %>

              <div class="flex flex-col items-center">
                <span class="font-bold text-gray-700 dark:text-gray-200">
                  <%= cur(total) %>
                </span>

                <%= display_basket_price_diff(info[:basket_price], total - info[:basket_price]) %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
