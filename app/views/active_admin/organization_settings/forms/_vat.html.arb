# frozen_string_literal: true

context.instance_eval do
  f.inputs t("active_admin.resources.organization.edit_model"), icon: "sliders-horizontal" do
    if section[:handbook] && !organization_setting_section_feature?(section)
      li class: "panel-actions" do
        text_node handbook_icon_link(section[:handbook], anchor: section[:handbook_anchor])
      end
    end

    f.input :vat_number, required: true, input_html: {
      placeholder: Current.org.swiss_qr? ? "CHE-123.456.789" : nil
    }
    f.input :vat_membership_rate, required: true, as: :number, min: 0, max: 100, step: 0.01,
      label: t("active_admin.resource.form.vat_rate", type: Membership.model_name.human(count: 2))
    if feature?("activity")
      f.input :vat_activity_rate, as: :number, min: 0, max: 100, step: 0.01,
        label: t("active_admin.resource.form.vat_rate", type: activities_human_name)
    end
    if feature?("shop")
      f.input :vat_shop_rate, as: :number, min: 0, max: 100, step: 0.01,
        label: t("active_admin.resource.form.vat_rate", type: t("shop.title"))
    end
  end
end
