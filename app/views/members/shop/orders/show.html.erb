<%= render partial: "members/shop/shared/header", locals: { order: @order } %>

<% case @order.state %>
<% when Shop::Order::CART_STATE %>
  <p class="mt-2">
    <%= t("members.shop.products.index.closing_at_html", date: l(@order.delivery.shop_closing_at, format: :long)) %>
    <%= " " %>
    <%= t(".finalize_order") %>
  </p>
  <section>
    <h2><%= t(".cart") %></h2>

    <%= turbo_frame_tag "order" do %>
      <%= render partial: "members/shop/orders/order", locals: { order: @order } %>
    <% end %>
  </section>
<% when Shop::Order::PENDING_STATE %>
  <p class="mt-2">
    <% if @order.can_member_update? %>
      <%= t(".received_order_html", date: l(@order.delivery.shop_closing_at, format: :long)) %>
    <% else %>
      <%= t(".pending_order_html") %>
    <% end %>
  </p>
  <section>
    <h2 class="flex items-center gap-2">
      <%= Shop::Order.model_name.human %>

      <% if @order.can_member_update? %>
        <span
          class="
            flex items-center rounded-full bg-green-300 px-3 text-sm
            font-normal text-green-700 dark:bg-green-700 dark:text-green-300
          "
        >
          <%= t(".order_received_state") %>
        </span>
      <% else %>
        <span
          class="
            flex items-center rounded-full bg-yellow-300 px-3 text-sm
            font-normal text-yellow-700 dark:bg-yellow-700
            dark:text-yellow-300
          "
        >
          <%= t(".order_pending_state") %>
        </span>
      <% end %>
    </h2>

    <%= render partial: "members/shop/orders/finalized_order", locals: { order: @order } %>
  </section>
<% when Shop::Order::INVOICED_STATE %>
  <p class="mt-2"><%= t(".invoiced_order_html") %></p>
  <div class="mt-4 mb-6">
    <%= link_to rails_blob_path(@order.invoice.pdf_file, disposition: "attachment") do %>
      <div
        class="
          mx-auto flex w-max flex-row items-center rounded-full border
          border-gray-300 px-4 py-1 text-gray-500 hover:border-green-300
          hover:text-green-500
        "
      >
        <%= icon "document-arrow-down", class: "size-5" %>

        <span class="ml-1">
          <%= t(".download_invoice_html", number: @order.invoice.id) %>
        </span>
      </div>
    <% end %>
  </div>
  <section>
    <h2 class="flex items-center gap-2">
      <%= Shop::Order.model_name.human %>

      <span
        class="
          flex items-center rounded-full bg-green-300 px-3 text-sm
          font-normal text-green-700 dark:bg-green-700 dark:text-green-300
        "
      >
        <%= t(".order_invoiced_state") %>
      </span>
    </h2>

    <%= render partial: "members/shop/orders/finalized_order", locals: { order: @order } %>
  </section>
<% end %>

<%= render "members/shop/shared/terms_of_sale" %>
