<p><%= t(".greeting") %></p>

<p><%= t(".still_remaining_paragraph") %></p>
<ul>
  {% if pending_memberships.size > 0 %}
  <li>
    <a href={{ pending_action_url }}>{{ pending_memberships.size }} <%= t(".pending_memberships_link") %></a> <%= t(".pending_memberships_suffix") %>
  </li>
  {% endif %}

  {% if opened_memberships.size > 0 %}
  <li>
    <a href={{ opened_action_url }}>{{ opened_memberships.size }} <%= t(".opened_memberships_link") %></a> <%= t(".opened_memberships_suffix") %>
  </li>
  {% endif %}
</ul>

<br/>
<p><%= t(".check_before_paragraph") %></p>

{% button action_url %}
  <%= t(".memberships_button") %>
{% endbutton %}
